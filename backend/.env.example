# Flask配置
FLASK_APP=app.main
FLASK_ENV=development
SECRET_KEY=your-secret-key-here
DEBUG=True

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ai_storybook
DB_USER=root
DB_PASSWORD=your-db-password

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# 阿里云OSS配置
OSS_ACCESS_KEY_ID=your-oss-access-key-id
OSS_ACCESS_KEY_SECRET=your-oss-access-key-secret
OSS_BUCKET_NAME=ai-storybook
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com

# 通义千问API配置
DASHSCOPE_API_KEY=your-dashscope-api-key

# 支付配置
WECHAT_PAY_APP_ID=your-wechat-app-id
WECHAT_PAY_MCH_ID=your-wechat-mch-id
WECHAT_PAY_API_KEY=your-wechat-api-key
WECHAT_PAY_CERT_PATH=path/to/cert
WECHAT_PAY_KEY_PATH=path/to/key

# 服务配置
SERVER_HOST=0.0.0.0
SERVER_PORT=5000
