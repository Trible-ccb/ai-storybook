# 环境变量配置

# ==================== 阿里云服务配置 ====================

# 通义千问/通义万相 API Key
# 获取地址：https://dashscope.aliyun.com/apiKey
QWEN_API_KEY=sk-your-qwen-api-key-here

# OSS 对象存储配置
# AccessKey 获取地址：https://ram.console.aliyun.com/manage/ak
OSS_ACCESS_KEY_ID=your-oss-access-key-id-here
OSS_ACCESS_KEY_SECRET=your-oss-access-key-secret-here

# OSS Bucket 配置
OSS_BUCKET_NAME=your-bucket-name
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# ==================== 数据库配置 ====================

# PostgreSQL 数据库 URL（部署到 Render 时自动提供）
# 格式：postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/aistorybook

# Redis 缓存 URL（可选）
# 格式：redis://password@host:port
REDIS_URL=redis://localhost:6379

# ==================== 应用配置 ====================

# Flask 配置
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-secret-key-here-change-in-production

# 服务器端口
PORT=5000

# ==================== 文件上传配置 ====================

# 允许的图片格式
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp

# 最大文件大小（MB）
MAX_FILE_SIZE=5

# ==================== 跨域配置 ====================

# 允许的前端域名（部署时修改）
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ==================== 限流配置 ====================

# API 请求速率限制（每分钟请求数）
RATE_LIMIT=60

# ==================== 日志配置 ====================

# 日志级别：DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=/tmp/openclaw/ai-storybook.log
